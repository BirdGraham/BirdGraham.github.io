        <textarea id="message" name="message" placeholder="Tell us about your student's target score, current score, or biggest struggles..." required></textarea>
      </div>
      <button type="submit" class="submit-btn">Book Free Consultation</button>
      <p class="form-note">We typically reply within 24 business hours to coordinate your free introductory strategy call.</p>
    </div>
  </form>

  <div id="form-success">
    🎉 Thank you! Your request has been submitted. We'll be in touch within 24 hours!
  </div>
</section>

<footer>
  <p>&copy; 2026 All About SAT. All Rights Reserved. | Handcrafted via <a href="https://pages.github.com" target="_blank">GitHub Pages</a></p>
</footer>

<script>
  let scores = { reading: 0, math: 0 };
  const answeredCards = new Set();
  const totalQuestionsPerTab = 10;

  function switchTab(tabName) {
    document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
    document.querySelectorAll('.tab-panel').forEach(panel => panel.classList.remove('active'));
    if (tabName === 'reading') {
      document.getElementById('btn-reading').classList.add('active');
      document.getElementById('reading-panel').classList.add('active');
    } else {
      document.getElementById('btn-math').classList.add('active');
      document.getElementById('math-panel').classList.add('active');
    }
  }

  function checkAnswer(button, choice, tab) {
    const card = button.closest('.q-card');
    const correctLetter = card.getAttribute('data-correct');
    if (answeredCards.has(card)) return;
    answeredCards.add(card);

    const buttons = card.querySelectorAll('.q-options button');
    buttons.forEach(btn => btn.disabled = true);

    if (choice === correctLetter) {
      button.classList.add('correct');
      scores[tab]++;
    } else {
      button.classList.add('wrong');
      buttons.forEach(btn => {
        if (btn.getAttribute('onclick').includes("'" + correctLetter + "'")) {
          btn.classList.add('show-correct');
        }
      });
    }

    const explanation = card.querySelector('.q-explanation');
    if (explanation) explanation.classList.add('visible');

    document.getElementById(tab + '-score-text').innerText = scores[tab];
    const pct = (scores[tab] / totalQuestionsPerTab) * 100;
    document.getElementById(tab + '-score-fill').style.width = pct + '%';
  }

  function handleFormSubmit(event) {
    event.preventDefault();
    const form = event.target;
    const data = new FormData(form);
    const successBanner = document.getElementById('form-success');

    fetch(form.action, {
      method: form.method,
      body: data,
      headers: { 'Accept': 'application/json' }
    }).then(response => {
      if (response.ok) {
        form.style.display = 'none';
        successBanner.style.display = 'block';
      } else {
        alert("Oops! There was a problem submitting your request.");
      }
    }).catch(() => {
      alert("Connection error. Please try again.");
    });
  }
</script>

</body>
</html>
